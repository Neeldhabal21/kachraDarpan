# KachraDarpan Email Credentials
# -----------------------------
# For Gmail, follow these steps:
# 1. Enable 2-Step Verification in your Google Account.
# 2. Search for "App Passwords" and create one for "Mail".
# 3. Use that 16-character password below.

# Service provider (e.g., gmail, outlook, hotmail)
EMAIL_SERVICE=gmail

# Your official email address
EMAIL_USER=your_official_email@gmail.com

# Your App Password (not your regular account password)
EMAIL_PASS=
